// ════════════════════════════════════════════════════════════════════════
//  관리 영역  ─  TrustScoreLog · AssetReport            [DRAFT 전반 — 산정/생성 로직 미정]
//  신뢰지수(Company.trustScore)는 대표인증·협업이행·결제이행·평판·재협업으로 산정되며
//  변동을 TrustScoreLog 로 남긴다(배치 갱신 가정). 자산레포트는 기업/프로젝트 협업역량을
//  종합 분석한 리포트(사업계획서상 AI 생성). 현 단계는 뼈대만 — 실제 산식/생성은 추후.
// ════════════════════════════════════════════════════════════════════════

/// [DRAFT] 신뢰지수 변동 이력(감사/추적). 갱신 후 점수 스냅샷 + 변동 사유.
model TrustScoreLog {
  id        String   @id @default(cuid()) /// [DRAFT] 고유 식별자 (cuid)
  delta     Int /// [DRAFT] 점수 변동량(+/-)
  score     Int /// [DRAFT] 변동 후 점수(스냅샷)
  reason    String? /// [DRAFT] 변동 사유(예: 협업 완료·납기 준수)
  createdAt DateTime @default(now()) /// [DRAFT] 변동 시각

  companyId String /// [DRAFT] 대상 기업 FK
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade) /// [DRAFT] 기업 관계

  @@index([companyId, createdAt]) /// [DRAFT] 기업별 변동 추이
}

/// [DRAFT] 자산레포트. 기업(+선택 프로젝트)의 협업 역량/이력 종합 분석 리포트. 내용은 Json 스냅샷.
model AssetReport {
  id          String   @id @default(cuid()) /// [DRAFT] 고유 식별자 (cuid)
  title       String /// [DRAFT] 리포트 제목
  summary     String? /// [DRAFT] 요약
  content     Json? /// [DRAFT] 구조화 본문(분석 결과 스냅샷)
  generatedAt DateTime /// [DRAFT] 생성 시각(생성 시 명시)

  createdAt DateTime @default(now()) /// [DRAFT] 저장 시각
  updatedAt DateTime @updatedAt /// [DRAFT] 최종 수정 시각

  companyId String /// [DRAFT] 대상 기업 FK
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade) /// [DRAFT] 기업 관계

  projectId String? /// [DRAFT] 관련 프로젝트 FK(선택)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull) /// [DRAFT] 프로젝트 관계

  @@index([companyId]) /// [DRAFT] 기업별 리포트 조회
}
