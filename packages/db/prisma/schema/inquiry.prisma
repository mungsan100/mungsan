// ════════════════════════════════════════════════════════════════════════
//  문의(고객센터)  ─  Inquiry
//  회원이 제목·내용으로 접수하면 운영자가 admin "문의 관리"에서 확인·처리한다(2026-07-20).
//  개발자가 상주하지 않는 운영 단계에서 사용자가 문제를 알릴 유일한 공식 창구.
// ════════════════════════════════════════════════════════════════════════

/// 문의 한 건. 처리 상태는 resolvedAt presence(시각 presence 컨벤션).
model Inquiry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 내용
  title   String
  content String

  // 처리 — command 가 명시(기본값 없음, 컨벤션). resolvedAt 있으면 처리 완료.
  resolvedAt        DateTime?
  resolvedByAdminId String? // 처리한 운영자(Admin.id, 무FK — 표시/감사용)
  adminNote         String? // 운영자 처리 메모(선택)

  // 문의자
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([resolvedAt, createdAt])
  @@index([authorId])
}
