// ════════════════════════════════════════════════════════════════════════
//  운영  ─  Admin
//  apps/admin 의 로그인 주체. 서비스 회원(User)과 별개 주체.
//  ※ 관리자 권한/역할 시스템(authority·super) 은 아직 없음 — 단순 운영자 계정만.
//    회원 가입 승인은 User.approvedAt 기록으로 처리(별도 심사 모델 없음).
// ════════════════════════════════════════════════════════════════════════

/// 운영자 계정.
model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
