// ════════════════════════════════════════════════════════════════════════
//  신고  ─  Report
//  회원이 콘텐츠(라운지 글/댓글, 협업 공고)를 신고하면 운영자가 admin 에서 심사한다.
//  대상은 폴리모픽(targetType+targetId, 무FK — attachment 컨벤션과 동일, 참조 무결성은
//  command 레벨). 신고 시점 원문을 contentSnapshot 으로 보존해 원문이 수정·삭제·숨김돼도
//  심사 근거가 남는다. 처리 = 콘텐츠 숨김(대상.hiddenAt 기록) 또는 반려. 자동 제재 없음.
// ════════════════════════════════════════════════════════════════════════

/// 콘텐츠 신고 한 건. 같은 사용자가 같은 대상을 중복 신고할 수 없다.
model Report {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 대상 (폴리모픽, 무FK)
  targetType ReportTargetType
  targetId   String

  // 신고 내용
  reason          ReportReason
  detail          String? // OTHER 선택 시 직접 입력(선택, ≤500자 — command 검증)
  contentSnapshot String // 신고 시점 원문(제목+본문, ≤2000자 절단) — 심사 근거 보존

  // 처리 — command 가 명시(기본값 없음, 컨벤션)
  status            ReportStatus
  resolvedAt        DateTime?
  resolvedByAdminId String? // 처리한 운영자(Admin.id, 무FK — 표시/감사용)

  // 신고자
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])

  @@unique([reporterId, targetType, targetId]) // 중복 신고 방지
  @@index([status, createdAt])
  @@index([targetType, targetId])
}

/// 신고 대상 종류.
enum ReportTargetType {
  LOUNGE_POST // LoungePost.id
  LOUNGE_COMMENT // LoungeComment.id (대댓글 포함)
  COLLABORATION_POST // CollaborationPost.id
}

/// 신고 사유.
enum ReportReason {
  SPAM // 스팸/광고
  ABUSE // 욕설/비방
  FALSE_INFO // 허위정보
  OTHER // 기타 (detail 에 직접 입력)
}

/// 신고 처리 상태 — 대기 → 콘텐츠 숨김(조치) 또는 반려(조치 없음).
enum ReportStatus {
  PENDING // 대기
  CONTENT_HIDDEN // 처리완료 — 콘텐츠 숨김 조치
  DISMISSED // 처리완료 — 반려(조치 없음)
}
