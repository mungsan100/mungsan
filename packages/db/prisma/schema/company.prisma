// ════════════════════════════════════════════════════════════════════════
//  기업  ─  Company
//  Company 는 관리자 마스터 데이터가 아니라 user 가 직접 입력해 소유하는 회사 프로필.
//  현재는 user 1명이 회사 1개를 소유하는 1:1(ownerId @unique). 회사명·사업자등록번호와
//  프로필(업종·소개·이력·태그·매출·설립일)·소유자 직책·검증상태를 한 행에 모은다
//  (증빙서류는 Attachment(ownerType=COMPANY)로 분리).
//  사업자등록번호는 중복 허용(같은 회사를 여러 user 가 각자 입력) — @unique 없이 인덱스만
//  둬, 훗날 동일 BRN 을 묶어 통합(멀티유저·회사 단일화)할 씨앗만 남긴다.
// ════════════════════════════════════════════════════════════════════════

/// user 가 소유하는 회사 프로필 (현재 user 1:1)
model Company {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 회사 기본 프로필
  name                   String // 회사명
  businessRegistrationNo String // 사업자등록번호
  // 회사 업종
  industryId             String
  industry               Industry @relation(fields: [industryId], references: [id])
  description            String? // 회사 소개
  trackRecord            String? // 주요 수행 이력 (프로즈)
  website                String? // 홈페이지
  revenueInCheonwon      Int? // 연매출(단위: 천 원)
  capabilityIds          String[] // 보유 역량(태그, NCS 상위 분류)

  // 상태
  deletedAt DateTime?

  // 회사 등록자
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}
