// ════════════════════════════════════════════════════════════════════════
//  공유 대시보드 / My 셰르파  ─  Project · Milestone · Task · TaskAttachment
//  협업 제안 수락 후 수행하는 프로젝트(컨소시엄의 MVP 형태).
//  Project → Milestone → Task(할 일) 계층. 초기 MVP 는 "내 업무 TO DO" 중심.
//  ※ 참여 주체(ProjectParticipant)는 시기상조로 보류 — 공고/수락 제안의 기업으로 1차 표현.
// ════════════════════════════════════════════════════════════════════════

// 협업 프로젝트(워크스페이스). 공고/수락 제안에서 파생. 진행률·기간·예산 관리.
model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title              String
  description        String?
  progressPercentage Int       @default(0) // 진행률 0~100 비정규화 스냅샷 (Task 기반 갱신)
  budgetInCheonwon   Int? // 할당 예산 (천 원 단위)
  startDate          DateTime? // 시작일
  endDate            DateTime? // 종료일

  // 사용자
  userId String
  user   User   @relation(fields: [userId], references: [id])

  milestones   Milestone[]
  tasks        Task[]
  assetReports AssetReport[]
}

// 마일스톤
model Milestone {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 기본 정보
  title     String
  startDate DateTime?
  endDate   DateTime?

  // 프로젝트
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  tasks Task[]

  @@index([projectId])
}

/// 할 일
model Task {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 기본 정보
  title       String // 업무명
  description String? // 업무 설명
  status      TaskStatus
  dueDate     DateTime? // 마감일
  completedAt DateTime? // 완료 처리 시각
  sort        String // 정렬 키

  // 프로젝트 (mileston.projectId 비정규화)
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  // 마일스톤
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  @@index([projectId, status])
  @@index([milestoneId])
}

// 할 일 상태.
enum TaskStatus {
  PLANNED // 예정
  IN_PROGRESS // 진행중
  COMPLETED // 완료
  ON_HOLD // 보류
}

// 중요도.
enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
}

// ────────────────────────────────────────────────────────────────────────
//  자산 리포트  ─  AssetReport
//  My 셰르파/관리 화면의 "산출물" — 회고 리포트·정산 서류·계약서. 프로젝트 수행의
//  결과물을 사용자가 보관/열람한다. 일부는 시스템이 자동 생성(autoGenerated).
//  실제 파일은 Attachment(추후) 또는 fileName/size 메타로 표현. FK 최소.
// ────────────────────────────────────────────────────────────────────────

/// 프로젝트 산출물/문서. 관리 화면의 자산 리포트 목록.
model AssetReport {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type          AssetReportType // 문서 종류
  title         String // 문서 제목
  autoGenerated Boolean // 시스템 자동 생성 여부
  reportDate    DateTime // 리포트 기준일
  fileName      String // 표시용 파일명
  fileSizeBytes Int // 표시용 파일 크기(바이트)

  // 소유자
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // 관련 프로젝트(선택)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([userId, reportDate])
}

/// 자산 리포트 종류.
enum AssetReportType {
  RETROSPECTIVE // 회고 리포트
  SETTLEMENT // 정산 서류
  CONTRACT // 계약서
}
