// ════════════════════════════════════════════════════════════════════════
//  협업 마켓플레이스  ─  CollaborationPost · CollaborationProposal · CollaborationBookmark
//  기업이 협업 공고(필요 파트너·역량·예산·기간·지역·마감)를 올리면, 다른 기업이
//  회사 소개서와 함께 제안을 보낸다. 제안 수락 시 Project(공유 대시보드)로 이어진다.
//  ※ ERD/IA 의 "협업 공고"가 정본 명칭(요구사항 PDF 의 "협업 펀드/금"은 OCR 오독).
// ════════════════════════════════════════════════════════════════════════

/// 협업 공고. 협업/프로젝트 수요를 공개 모집. 검색·필터(업종·역량·지역·예산·마감)·저장 대상.
model CollaborationPost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 기본 정보
  title               String // 협업 공고 제목
  description         String // 협업 설명
  minBudgetInCheonwon Int? // 최소 예산 (천 원 단위)
  maxBudgetInCheonwon Int? // 최대 예산 (천 원 단위)
  region              String? // 지역
  collaborationMethod String? // 협업 방식
  startDate           DateTime? // 시작일
  endDate             DateTime? // 종료일
  applicationDeadline DateTime? // 신청 마감일 — 지나면 새 제안 불가, 목록에 "마감" 표시
  requiredSkillIds    String[] // 필요 역량 id — Skill.id
  industryTagIds      String[] // 업종 태그 id — Industry.id
  partnerTypes        String[] // 필요한 파트너사 유형 — 자유 태그(카탈로그 아님, 예: "B2B 영업사")

  // 상태
  isPublic  Boolean // 공개 여부
  deletedAt DateTime?
  hiddenAt  DateTime? // 운영 숨김(신고 처리) — 삭제와 구분, null 복원으로 되돌림

  // 비정규화
  viewCount     Int @default(0) // 조회수
  proposalCount Int @default(0) // 제안수 캐시
  bookmarkCount Int @default(0) // 저장수 캐시

  // 작성자
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  proposals CollaborationProposal[]
  bookmarks CollaborationBookmark[]
}

/// 협업 제안. 공고를 본 기업이 회사소개서·제안 메시지·역할/기여로 제안.
model CollaborationProposal {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 내용 — message 는 5개 구조화 필드를 합친 전문(구조화 이전 데이터·기존 화면과 호환).
  // 구조화 필드(PRD FR-CLBMK-3)는 개별 컬럼으로도 저장해 새 화면이 항목별로 표시한다.
  message                String // 제안 메시지 전문
  introduction           String? // 자기소개
  interestReason         String? // 관심 이유
  contributionCapability String? // 기여 가능 역량
  collaborationMethod    String? // 협업 가능 방식
  meetingAvailability    String? // 미팅 가능 일정
  contributionRole       String? // 기여 역할(협업 가능 영역)

  // 상태
  status      ProposalStatus // 제안 상태 워크플로 — 커맨드가 명시값을 보낸다(@default 없음, 컨벤션)
  respondedAt DateTime? // 공고 측 응답
  viewedAt    DateTime? // 공고 작성자가 제안을 열람한 시각(읽음 추적 — unread/viewed/replied 파생)

  // 공고
  postId String
  post   CollaborationPost @relation(fields: [postId], references: [id])

  // 제안자
  proposerId String
  proposer   User   @relation(fields: [proposerId], references: [id])
}

/// 제안 상태 워크플로 — (임시저장) → 제안완료 → 검토중 → 수락/반려/미팅요청 → 협업진행중.
/// 열람(viewedAt 기록) 시 SUBMITTED→UNDER_REVIEW 전이, 응답 액션이 respondedAt과 함께
/// ACCEPTED/REJECTED/MEETING_REQUESTED 기록. IN_PROGRESS는 수락 시 Project 생성과 함께 전이.
/// DRAFT 는 제안자 본인만 보는 임시저장 — 받은제안 목록·proposalCount 에서 제외해야 한다.
enum ProposalStatus {
  DRAFT // 임시저장(미제출 — 공고 작성자에게 보이지 않음)
  SUBMITTED // 제안 완료(미열람)
  UNDER_REVIEW // 검토 중(공고 작성자가 열람)
  ACCEPTED // 수락
  REJECTED // 반려
  MEETING_REQUESTED // 미팅 요청
  IN_PROGRESS // 협업 진행 중
}

/// 협업 공고 저장/북마크
model CollaborationBookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // 협업 공고
  postId String
  post   CollaborationPost @relation(fields: [postId], references: [id])

  // 북마크를 누른 사용자
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([postId, userId]) // 중복 저장 방지
  @@index([userId]) // 사용자별 저장 목록
}
